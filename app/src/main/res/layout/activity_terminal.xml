<?xml version="1.0" encoding="utf-8"?>
<!-- Kept for reference; the app renders TerminalActivity via Compose
     (see TerminalScreen.kt). This layout exists for any consumer that
     wants a classic XML/View-based host for TerminalView. -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/terminal_bg">

    <com.aashutarminal.terminal.TerminalView
        android:id="@+id/terminalView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

</FrameLayout>
